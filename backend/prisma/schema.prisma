generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  CLINIC_ADMIN
  PROFESSIONAL
  SUPER_ADMIN
}

enum CareRequestStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id                  String                @id @default(uuid())
  email               String                @unique
  passwordHash        String
  role                Role
  firstName           String?
  lastName            String?
  phone               String?
  isActive            Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  patientProfile      PatientProfile?
  professionalProfile ProfessionalProfile?
  clinicMemberships   ClinicMember[]
  refreshTokens       RefreshToken[]
  uploadedDocuments   MedicalDocument[]     @relation("UploadedDocuments")
  auditLogs           AuditLog[]            @relation("AuditActor")
  createdAppointments Appointment[]         @relation("AppointmentCreator")

  @@index([role])
}

model PatientProfile {
  id                    String            @id @default(uuid())
  userId                String            @unique
  dateOfBirth           DateTime?
  gender                String?
  address               String?
  emergencyContactName  String?
  emergencyContactPhone String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  careRequests          CareRequest[]
  appointments          Appointment[]
  documents             MedicalDocument[]
  notes                 ClinicalNote[]
}

model Clinic {
  id           String         @id @default(uuid())
  name         String
  slug         String         @unique
  email        String?
  phone        String?
  address      String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  members      ClinicMember[]
  careRequests CareRequest[]
  appointments Appointment[]
}

model ClinicMember {
  id        String   @id @default(uuid())
  clinicId  String
  userId    String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clinicId, userId])
  @@index([userId])
}

model ProfessionalProfile {
  id                  String         @id @default(uuid())
  userId              String         @unique
  specialty           String?
  licenseNumber       String?
  bio                 String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  careRequests        CareRequest[]  @relation("CareRequestProfessional")
  appointments        Appointment[]
  notes               ClinicalNote[]
}

model CareRequest {
  id            String            @id @default(uuid())
  patientId     String
  clinicId      String?
  professionalId String?
  title         String
  description   String
  preferredDate DateTime?
  status        CareRequestStatus @default(DRAFT)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  patient       PatientProfile    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic        Clinic?           @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  professional  ProfessionalProfile? @relation("CareRequestProfessional", fields: [professionalId], references: [id], onDelete: SetNull)
  appointments  Appointment[]
  documents     MedicalDocument[]
  notes         ClinicalNote[]

  @@index([patientId])
  @@index([clinicId])
  @@index([professionalId])
  @@index([status])
}

model Appointment {
  id                 String            @id @default(uuid())
  patientId          String
  clinicId           String?
  professionalId     String?
  careRequestId      String?
  createdById        String?
  scheduledAt        DateTime
  endAt              DateTime?
  location           String?
  notes              String?
  cancellationReason String?
  status             AppointmentStatus @default(REQUESTED)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  patient            PatientProfile    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic             Clinic?           @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  professional       ProfessionalProfile? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  careRequest        CareRequest?      @relation(fields: [careRequestId], references: [id], onDelete: SetNull)
  createdBy          User?             @relation("AppointmentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  clinicalNotes      ClinicalNote[]

  @@index([patientId])
  @@index([clinicId])
  @@index([professionalId])
  @@index([careRequestId])
  @@index([scheduledAt])
  @@index([status])
}

model MedicalDocument {
  id            String         @id @default(uuid())
  patientId     String
  careRequestId String?
  uploadedById  String
  fileName      String
  mimeType      String
  fileSize      Int
  storageKey    String
  documentType  String
  createdAt     DateTime       @default(now())
  patient       PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  careRequest   CareRequest?   @relation(fields: [careRequestId], references: [id], onDelete: SetNull)
  uploadedBy    User           @relation("UploadedDocuments", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([careRequestId])
  @@index([uploadedById])
}

model ClinicalNote {
  id            String               @id @default(uuid())
  patientId     String
  professionalId String
  careRequestId String?
  appointmentId String?
  content       String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  patient       PatientProfile       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional  ProfessionalProfile  @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  careRequest   CareRequest?         @relation(fields: [careRequestId], references: [id], onDelete: SetNull)
  appointment   Appointment?         @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([professionalId])
  @@index([careRequestId])
  @@index([appointmentId])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
