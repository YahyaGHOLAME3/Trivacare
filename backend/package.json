{
  "name": "trivacare-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node --project tsconfig.json src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "migrate:deploy": "prisma migrate deploy",
    "seed:admin": "tsx prisma/seed-admin.ts",
    "test:patient": "node --import tsx --test tests/patient-prod-readiness.test.ts",
    "test:personas": "node --import tsx --test tests/persona-prod-readiness.test.ts",
    "start": "node --env-file=.env dist/main.js",
    "start:prod": "node --env-file=.env dist/main.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@prisma/client": "^6.19.2",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^6.19.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
