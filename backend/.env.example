NODE_ENV=development
PORT=3001
API_PREFIX=
DATABASE_URL=postgresql://trivacare:trivacare@127.0.0.1:5432/trivacare?schema=public
JWT_ACCESS_SECRET=replace-with-32-plus-char-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-32-plus-char-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
BILLING_PROVIDER_WEBHOOK_SECRET=replace-with-32-plus-char-webhook-secret
CORS_ORIGIN=http://localhost:4173,http://127.0.0.1:4173,http://localhost:5173,http://127.0.0.1:5173

# Local admin seed only. Set explicitly before running `npm run seed:admin`.
ADMIN_EMAIL=admin@example.test
ADMIN_PASSWORD=replace-with-local-admin-password
